                  <Insets top="5.0" />
               </VBox.margin>
            </Text>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="- Un triple : la tuile jouée correspond par couleur ou symbole sur trois de ses cotés, vous gagnez 2 points">
