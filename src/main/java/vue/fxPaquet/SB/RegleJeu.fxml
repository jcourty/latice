   <center>
      <VBox prefHeight="400.0" prefWidth="627.0" BorderPane.alignment="CENTER">
         <children>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="En jouant à Latice, vous n'avez qu'un seul objectif: être le premier à vider votre pioche en seulement dix tours.">
