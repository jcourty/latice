package vue.fxPaquet.SB

import javafx.geometry.Insets
import javafx.scene.layout.BorderPane
import javafx.scene.layout.VBox
import javafx.scene.text.Text

component RegleJeu{BorderPane{maxHeight:-Infinity,maxWidth:-Infinity,minHeight:-Infinity,minWidth:-Infinity,prefHeight:500.0,prefWidth:741.0,center:VBox{prefHeight:400.0,prefWidth:627.0,call BorderPane#alignment:"CENTER",Insets{left:10.0},call BorderPane#margin:"",padding:Insets{top:40.0},children:[Text{strokeType:"OUTSIDE",strokeWidth:0.0,text:"En jouant à Latice, vous n'avez qu'un seul objectif: être le premier à vider votre pioche en seulement dix tours.",Insets{top:100.0},call VBox#margin:""},Text{strokeType:"OUTSIDE",strokeWidth:0.0,text:"Pour cela, rien de plus simple: il vous suffit de poser vos tuiles à coté de celles déjà sur le plateau. Mais attention, seule une tuile similaire, par le symbole ou bien la couleur, est acceptée.",wrappingWidth:568.658203125},Text{strokeType:"OUTSIDE",strokeWidth:0.0,text:"À chaque tour vous pouvez soit échanger votre chevalet, soit passer votre tour, soit obtenir des actions supplémentaires coûtant 2 points.",wrappingWidth:547.900390625},Text{strokeType:"OUTSIDE",strokeWidth:0.0,text:"Le système de points fonctionne ainsi :",Insets{top:10.0},call VBox#margin:""},Text{strokeType:"OUTSIDE",strokeWidth:0.0,text:"- Un double : la tuile jouée correspond par couleur ou symbole sur deux de ses cotés, vous gagnez 1 point",Insets{top:5.0},call VBox#margin:""},Text{strokeType:"OUTSIDE",strokeWidth:0.0,text:"- Un triple : la tuile jouée correspond par couleur ou symbole sur trois de ses cotés, vous gagnez 2 points",Insets{top:5.0},call VBox#margin:""},Text{strokeType:"OUTSIDE",strokeWidth:0.0,text:"- Un Latice : la tuile jouée correspond par couleur ou symbole sur quatre de ses cotés, vous gagnez 4 points",Insets{top:5.0},call VBox#margin:""},Text{strokeType:"OUTSIDE",strokeWidth:0.0,text:"- Placez votre tuile sur un soleil pour gagner 2 points",Insets{top:5.0},call VBox#margin:""}]}}}
